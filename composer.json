{
    "name": "pasaia/sso-client-bundle",
    "description": "Symfony bundle for authenticating against the SSO Municipal Pasaia (OpenID Connect)",
    "type": "symfony-bundle",
    "license": "proprietary",
    "require": {
        "php": ">=8.2",
        "drenso/symfony-oidc-bundle": "^4.0",
        "symfony/config": "^6.4 || ^7.0 || ^8.0",
        "symfony/dependency-injection": "^6.4 || ^7.0 || ^8.0",
        "symfony/framework-bundle": "^6.4 || ^7.0 || ^8.0",
        "symfony/http-foundation": "^6.4 || ^7.0 || ^8.0",
        "symfony/routing": "^6.4 || ^7.0 || ^8.0",
        "symfony/security-bundle": "^6.4 || ^7.0 || ^8.0",
        "symfony/security-core": "^6.4 || ^7.0 || ^8.0",
        "symfony/security-http": "^6.4 || ^7.0 || ^8.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-symfony": "^2.0",
        "phpunit/phpunit": "^11.0",
        "symfony/http-kernel": "^6.4 || ^7.0 || ^8.0",
        "symfony/phpunit-bridge": "^6.4 || ^7.0 || ^8.0"
    },
    "autoload": {
        "psr-4": {
            "Pasaia\\SsoClientBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Pasaia\\SsoClientBundle\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "symfony/flex": true
        }
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "recipe-dir": "symfony/recipes"
        }
    }
}
